# CodePilot Review 环境配置
APP_NAME="CodePilot Review"
APP_VERSION="0.1.0"
APP_ENV=development

# 前端地址，用于 CORS
FRONTEND_ORIGIN=http://localhost:5173

# GitHub Token (第 1 天 Demo 模式不需要)
GITHUB_TOKEN=

# 模型配置 (第 2 天接入)
MODEL_PROVIDER=deepseek
MODEL_NAME=deepseek-v4-pro
REQUEST_TIMEOUT_SECONDS=120

# Demo 模式开关
DEMO_MODE=true
